# ==========================================================
#  PLANTILLA. Copia este archivo como  .env  y rellena tus
#  credenciales reales. El archivo .env está en .gitignore
#  y NUNCA debe subirse a GitHub.
# ==========================================================

# Cadena de conexión SQLAlchemy a Azure SQL (lectura).
# La contraseña debe ir URL-encoded:  @ -> %40   : -> %3A   etc.
DATABASE_URL=mssql+pyodbc://USUARIO:PASSWORD@SERVIDOR.database.windows.net:1433/BASEDEDATOS?driver=ODBC+Driver+18+for+SQL+Server&Encrypt=yes&TrustServerCertificate=no

# Modo de origen de datos: "sql" (Azure) o "synthetic" (datos simulados para desarrollo)
DATA_SOURCE=synthetic
